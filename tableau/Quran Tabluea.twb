            <column-instance column='[revelation_place]' derivation='None' name='[none:revelation_place:nk]' pivot='key' type='nominal' />
            <column caption='Revelation Order' datatype='integer' name='[revelation_order]' role='measure' type='quantitative' />
            <column caption='Revelation Place' datatype='string' name='[revelation_place]' role='dimension' type='nominal' />
            <column-instance column='[revelation_order]' derivation='Sum' name='[sum:revelation_order:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
